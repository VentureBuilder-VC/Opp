# Local development — used by browser directly
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Production (Vercel) — used by serverless proxy, never exposed to browser
# Set this in Vercel dashboard > Settings > Environment Variables
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Supabase (optional — falls back to localStorage if not set) ──
# Create a project at https://supabase.com, then run supabase/schema.sql
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Google OAuth ──
# VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
